{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/chat/(.*)", "destination": "/api/index.py" },
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/account/(.*)", "destination": "/api/index.py" },
    { "source": "/events/(.*)", "destination": "/api/index.py" },
    { "source": "/groups/(.*)", "destination": "/api/index.py" },
    { "source": "/recommendations/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
